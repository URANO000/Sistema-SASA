@model DataAccess.Modelos.Entidades.Inventario.ActivoInventario

@if (Model == null)
{
    <div class="alert alert-danger">No se pudo cargar el activo.</div>
    return;
}

@{
    ViewData["Title"] = "Detalle del Activo";
}

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-start mb-4">
                <div>
                    <h4 class="mb-1 fw-bold">Detalle del Activo</h4>
                    <div class="text-muted">Código único para trazabilidad física/digital (QR)</div>
                </div>

                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.IdActivo" class="btn btn-outline-primary">
                        Editar
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Volver
                    </a>
                </div>
            </div>

            <div class="row g-4">
                <!-- Info -->
                <div class="col-lg-7">
                    <div class="mb-3">
                        <div class="text-muted">Código del activo</div>
                        <div class="fs-5 fw-semibold">@Model.NumeroActivo</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="text-muted">Nombre</div>
                            <div>@(Model.NombreMaquina ?? "-")</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="text-muted">Tipo</div>
                            <div>@(Model.TipoActivo?.Nombre ?? "-")</div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="text-muted">Estado</div>
                            <div>@(Model.EstadoActivo?.Nombre ?? "-")</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="text-muted">Serie / Service Tag</div>
                            <div>@(Model.SerieServicio ?? "-")</div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="text-muted">Marca</div>
                            <div>@(Model.Marca ?? "-")</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="text-muted">Modelo</div>
                            <div>@(Model.Modelo ?? "-")</div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="text-muted">MAC</div>
                            <div>@(Model.DireccionMAC ?? "-")</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="text-muted">Sistema Operativo</div>
                            <div>@(Model.SistemaOperativo ?? "-")</div>
                        </div>
                    </div>
                </div>

                <!-- QR -->
                <div class="col-lg-5">
                    <div class="border rounded p-3 h-100 d-flex flex-column align-items-center justify-content-center">
                        <div class="fw-semibold mb-2">QR del Activo</div>

                        <div id="qrcode" class="mb-2"></div>

                        <div class="text-muted small text-center">
                            Escanee este código para identificar el activo rápidamente.
                        </div>

                        <button type="button" class="btn btn-outline-dark mt-3" onclick="window.print()">
                            Imprimir etiqueta
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <!-- Librería QR (cliente) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

    <script>
        // Genera QR basado en el código único del activo
        const codigo = "@Model.NumeroActivo";
        new QRCode(document.getElementById("qrcode"), {
            text: codigo,
            width: 160,
            height: 160
        });
    </script>
}
