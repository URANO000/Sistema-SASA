@model SASA.ViewModels.Inventario.ReporteGeneralInventarioViewModel

@{
    ViewData["Title"] = "Reporte General de Inventario";

    string BuildUrl(int pageNumber)
        => Url.Action("GeneralReport", "Inventory", new
        {
            pageNumber = pageNumber,
            pageSize = Model.PageSize
        })!;
}

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-body">

            <h4 class="fw-bold mb-1">Reporte General de Inventario</h4>
            <p class="text-muted mb-4">
                Visualización general del estado de los activos registrados en el sistema.
            </p>

            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h6 class="text-muted">Total de Activos</h6>
                            <h3 class="fw-bold">@Model.TotalActivos</h3>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h6 class="text-muted">Activos Activos</h6>
                            <h3 class="fw-bold text-success">@Model.ActivosActivos</h3>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h6 class="text-muted">En Mantenimiento</h6>
                            <h3 class="fw-bold text-warning">@Model.EnMantenimiento</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items != null && Model.Items.Any())
                        {
                            foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.NumeroActivo</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.NombreMaquina) ? "-" : item.NombreMaquina)</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.TipoActivoNombre) ? "-" : item.TipoActivoNombre)</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(item.EstadoActivoNombre))
                                        {
                                            <span class="badge bg-secondary">@item.EstadoActivoNombre</span>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    No hay activos para mostrar.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 mt-3">
                <div class="text-muted small">
                    Página <strong>@Model.PageNumber</strong> de <strong>@Model.TotalPages</strong>
                </div>

                <nav aria-label="Paginación reporte general">
                    <ul class="pagination mb-0">
                        <li class="page-item @(!Model.HasPrev ? "disabled" : "")">
                            <a class="page-link"
                                   href="@(!Model.HasPrev ? "#" : BuildUrl(Model.PageNumber - 1))">
                                Anterior
                            </a>
                        </li>

                        <li class="page-item active">
                            <span class="page-link">@Model.PageNumber</span>
                        </li>

                        <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                            <a class="page-link"
                                   href="@(!Model.HasNext ? "#" : BuildUrl(Model.PageNumber + 1))">
                                Siguiente
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>

            <div class="d-flex justify-content-end mt-3">
                <a asp-action="Reports" class="btn btn-outline-secondary">
                    Volver
                </a>
            </div>

        </div>
    </div>
</div>