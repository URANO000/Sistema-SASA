@model SASA.ViewModels.Inventario.CrearMantenimientoViewModel

@{
    ViewData["Title"] = "Registrar Mantenimiento";
}

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-body">

            <h4 class="mb-1 fw-bold">Registrar Mantenimiento</h4>
            <p class="text-muted mb-4">
                Ingrese la información del mantenimiento realizado al activo.
            </p>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <form asp-controller="Inventory" asp-action="CreateMaintenance" method="post">
                @Html.AntiForgeryToken()

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="IdActivo" class="form-label">Activo</label>
                        <select asp-for="IdActivo" asp-items="Model.Activos" class="form-select">
                            <option value="">Seleccione un activo</option>
                        </select>
                        <span asp-validation-for="IdActivo" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="FechaMantenimiento" class="form-label">Fecha de mantenimiento</label>
                        <input asp-for="FechaMantenimiento" type="date" class="form-control" />
                        <span asp-validation-for="FechaMantenimiento" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="TipoMantenimiento" class="form-label">Tipo de mantenimiento</label>
                        <select asp-for="TipoMantenimiento" class="form-select">
                            <option value="">Seleccione un tipo</option>
                            <option value="Preventivo">Preventivo</option>
                            <option value="Correctivo">Correctivo</option>
                        </select>
                        <span asp-validation-for="TipoMantenimiento" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Estado" class="form-label">Estado</label>
                        <select asp-for="Estado" class="form-select">
                            <option value="Finalizado">Finalizado</option>
                            <option value="En proceso">En proceso</option>
                        </select>
                        <span asp-validation-for="Estado" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Descripcion" class="form-label">Descripción</label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"
                              placeholder="Detalle del mantenimiento realizado"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end">
                    <a asp-action="Maintenance" class="btn btn-outline-secondary me-2">
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>
                        Registrar Mantenimiento
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}