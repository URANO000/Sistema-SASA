@model SASA.ViewModels.Inventario.InventarioIndexViewModel

@{
    ViewData["Title"] = "Activos de Equipos";

    string BuildUrl(string sortBy, string sortDir, int pageNumber)
        => Url.Action("Index", "Inventory", new
        {
            q = Model.Q,
            estadoId = Model.EstadoId,
            tipoId = Model.TipoId,
            pageNumber = pageNumber,
            pageSize = Model.PageSize,
            sortBy = sortBy,
            sortDir = sortDir
        })!;
}

<div class="container-fluid">

    <div class="card mb-3">
        <div class="card-body">

            <!-- Header -->
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
                <div>
                    <h4 class="mb-0 fw-bold">Gestión de Activos de Equipos</h4>
                    <small class="text-muted">
                        Administre y supervise los activos de equipos registrados en el sistema.
                    </small>
                </div>

                @if (User.IsInRole("Administrador"))
                {
                    <div class="d-flex gap-2">
                        <a class="btn btn-custom" asp-controller="Inventory" asp-action="Create">
                            <i class="bi bi-plus-lg"></i>
                            Nuevo Activo
                        </a>
                    </div>
                }
            </div>

            <!-- Filters -->
            <form method="get">
                <input type="hidden" name="pageNumber" value="1" />
                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDir" value="@Model.SortDir" />

                <div class="row g-2 mb-3">
                    <div class="col-12 col-md-4">
                        <input type="text"
                               name="q"
                               value="@Model.Q"
                               class="form-control"
                               placeholder="Buscar por nombre o código..." />
                    </div>

                    <div class="col-12 col-md-4">
                        <select class="form-select"
                                name="estadoId"
                                asp-items="Model.Estados">
                            <option value="">Estado</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-2">
                        <select class="form-select"
                                name="tipoId"
                                asp-items="Model.Tipos">
                            <option value="">Tipo de Activo</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-2">
                        <button class="btn btn-outline-secondary w-100" type="submit">
                            <i class="bi bi-funnel"></i>
                            Filtrar
                        </button>
                    </div>
                </div>
            </form>

            <!-- Table -->
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="width:140px;">Acciones</th>

                            <th>
                                <a class="text-decoration-none"
                                   href="@BuildUrl("Codigo", Model.ToggleDir("Codigo"), 1)">
                                    Código @Model.SortIcon("Codigo")
                                </a>
                            </th>

                            <th>
                                <a class="text-decoration-none"
                                   href="@BuildUrl("Nombre", Model.ToggleDir("Nombre"), 1)">
                                    Nombre @Model.SortIcon("Nombre")
                                </a>
                            </th>

                            <th class="d-none d-md-table-cell">
                                <a class="text-decoration-none"
                                   href="@BuildUrl("Tipo", Model.ToggleDir("Tipo"), 1)">
                                    Tipo @Model.SortIcon("Tipo")
                                </a>
                            </th>

                            <th class="d-none d-md-table-cell">
                                <a class="text-decoration-none"
                                   href="@BuildUrl("Estado", Model.ToggleDir("Estado"), 1)">
                                    Estado @Model.SortIcon("Estado")
                                </a>
                            </th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.Items != null && Model.Items.Any())
                        {
                            foreach (var a in Model.Items)
                            {
                                <tr>
                                    <td class="text-center">
                                        <button type="button"
                                                class="btn btn-link p-0 me-2"
                                                title="Ver detalle"
                                                data-bs-toggle="modal"
                                                data-bs-target="#activoDetailModal"
                                                data-id="@a.IdActivo">
                                            <i class="bi bi-eye detail-btn"></i>
                                        </button>

                                        @if (User.IsInRole("Administrador"))
                                        {
                                            <button type="button"
                                                    class="btn btn-link p-0 me-2"
                                                    title="Editar"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#activoEditModal"
                                                    data-id="@a.IdActivo">
                                                <i class="fa-regular fa-pen-to-square edit-btn"></i>
                                            </button>
                                        }
                                    </td>

                                    <td class="fw-semibold">@a.NumeroActivo</td>
                                    <td>@a.NombreMaquina</td>

                                    <td class="d-none d-md-table-cell">@(!string.IsNullOrWhiteSpace(a.TipoActivoNombre) ? a.TipoActivoNombre : "-")</td>

                                    <td class="d-none d-md-table-cell">
                                        <span class="badge bg-secondary">
                                            @(!string.IsNullOrWhiteSpace(a.EstadoActivoNombre) ? a.EstadoActivoNombre : "-")
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    No se encontraron activos registrados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Paginación -->
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 mt-3">
                <div class="text-muted small">
                    Página <strong>@Model.PageNumber</strong> de <strong>@Model.TotalPages</strong>
                </div>

                <nav aria-label="Paginación">
                    <ul class="pagination mb-0">
                        <li class="page-item @(!Model.HasPrev ? "disabled" : "")">
                            <a class="page-link"
                               href="@(!Model.HasPrev ? "#" : BuildUrl(Model.SortBy, Model.SortDir, Model.PageNumber - 1))">
                                Anterior
                            </a>
                        </li>

                        <li class="page-item active">
                            <span class="page-link">@Model.PageNumber</span>
                        </li>

                        <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                            <a class="page-link"
                               href="@(!Model.HasNext ? "#" : BuildUrl(Model.SortBy, Model.SortDir, Model.PageNumber + 1))">
                                Siguiente
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>

            <!-- Modal (Detalle) -->
            <div class="modal fade" id="activoDetailModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-scrollable">
                    <div class="modal-content" id="activoDetailModalContent">
                        <div class="modal-body text-center p-4 text-muted">
                            Seleccione un activo...
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal (Editar) -->
            <div class="modal fade" id="activoEditModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-lg" style="max-height: calc(100vh - 3.5rem);">
                    <div class="modal-content" id="activoEditModalContent" style="max-height: calc(100vh - 3.5rem); overflow: hidden;">
                        <div class="modal-body" style="overflow-y: auto; max-height: calc(100vh - 12rem);">
                            <div class="text-center p-4 text-muted">
                                Cargando...
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="successModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-sm modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Cambios guardados</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                        </div>
                        <div class="modal-body">
                            <div class="d-flex align-items-start gap-2">
                                <i class="bi bi-check-circle-fill text-success fs-4"></i>
                                <div>
                                    <div class="fw-semibold">Éxito</div>
                                    <div class="text-muted small">El activo se actualizó correctamente.</div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-success w-100" data-bs-dismiss="modal">
                                Aceptar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

    <script>
        // ============================
        // DETALLE MODAL
        // ============================
        const detailModal = document.getElementById('activoDetailModal');
        const detailContent = document.getElementById('activoDetailModalContent');

        detailModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');

            detailContent.innerHTML = `<div class="modal-body text-center p-4 text-muted">Cargando...</div>`;

            fetch(`/Inventory/DetailModal?id=${id}`, { credentials: "same-origin" })
                .then(r => {
                    if (!r.ok) throw new Error("No se pudo cargar el detalle.");
                    return r.text();
                })
                .then(html => {
                    detailContent.innerHTML = html;

                    const qrDiv = document.getElementById("qrcodeModal");
                    if (qrDiv && window.QRCode) {
                        const codigo = qrDiv.getAttribute("data-code") || "";
                        qrDiv.innerHTML = "";
                        new QRCode(qrDiv, { text: codigo, width: 160, height: 160 });
                    }
                })
                .catch(() => {
                    detailContent.innerHTML = `
                        <div class="modal-body p-4">
                            <div class="alert alert-danger mb-0">
                                Error cargando detalle.
                            </div>
                        </div>`;
                });
        });

        detailModal.addEventListener('hidden.bs.modal', function () {
            detailContent.innerHTML = `<div class="modal-body text-center p-4 text-muted">Seleccione un activo...</div>`;
        });
    </script>

    <script>
        // ============================
        // EDIT MODAL
        // ============================
        const editModal = document.getElementById('activoEditModal');
        const editContent = document.getElementById('activoEditModalContent');

        function wireEditForm(id) {
            if (window.jQuery && jQuery.validator && jQuery.validator.unobtrusive) {
                jQuery.validator.unobtrusive.parse(editContent);
            }

            const form = document.getElementById("editActivoForm");
            if (!form) return;

            form.addEventListener("submit", function (e) {
                e.preventDefault();

                const formData = new FormData(form);

                fetch(`/Inventory/EditModal?id=${id}`, {
                    method: "POST",
                    body: formData,
                    headers: { "X-Requested-With": "XMLHttpRequest" },
                    credentials: "same-origin"
                })
                .then(async r => {
                    const ct = r.headers.get("content-type") || "";

                    if (ct.includes("application/json")) {
                        const data = await r.json();
                        if (data.success) {
                            const editInstance = bootstrap.Modal.getOrCreateInstance(editModal);
                            editInstance.hide();

                            const successModalEl = document.getElementById('successModal');
                            const successInstance = bootstrap.Modal.getOrCreateInstance(successModalEl);
                            successInstance.show();

                            setTimeout(() => {
                                successInstance.hide();
                            }, 1500);

                            successModalEl.addEventListener('hidden.bs.modal', function handler() {
                                successModalEl.removeEventListener('hidden.bs.modal', handler);
                                window.location.reload();
                            });

                            return;
                        }
                    }

                    const html = await r.text();
                    editContent.innerHTML = html;
                    wireEditForm(id);
                })
                .catch(() => {
                    editContent.innerHTML = `
                        <div class="modal-body p-4">
                            <div class="alert alert-danger mb-0">
                                Error guardando cambios.
                            </div>
                        </div>`;
                });
            }, { once: true });
        }

        editModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');

            editContent.innerHTML = `<div class="modal-body text-center p-4 text-muted">Cargando...</div>`;

            fetch(`/Inventory/EditModal?id=${id}`, { credentials: "same-origin" })
                .then(r => {
                    if (!r.ok) throw new Error("No se pudo cargar el formulario.");
                    return r.text();
                })
                .then(html => {
                    editContent.innerHTML = html;
                    wireEditForm(id);
                })
                .catch(() => {
                    editContent.innerHTML = `
                        <div class="modal-body p-4">
                            <div class="alert alert-danger mb-0">
                                Error cargando formulario.
                            </div>
                        </div>`;
                });
        });

        editModal.addEventListener('hidden.bs.modal', function () {
            editContent.innerHTML = `<div class="modal-body text-center p-4 text-muted">Seleccione un activo...</div>`;
        });
    </script>
}