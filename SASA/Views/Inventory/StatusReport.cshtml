@model SASA.ViewModels.Inventario.ReporteEstadoInventarioViewModel

@{
    ViewData["Title"] = "Reporte por Estado";
}

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-body">

            <h4 class="fw-bold mb-1">Reporte por Estado</h4>
            <p class="text-muted mb-4">
                Distribución de los activos según su estado actual.
            </p>

            <div class="row">
                <div class="col-md-6">
                    <ul class="list-group">
                        @if (Model.Estados != null && Model.Estados.Any())
                        {
                            foreach (var estado in Model.Estados)
                            {
                                <li class="list-group-item d-flex justify-content-between">
                                    @estado.Key
                                    <span class="badge bg-secondary">@estado.Value</span>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item text-muted">
                                No hay datos de estados para mostrar.
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <div class="d-flex justify-content-end mt-3">
                <a asp-action="Reports" class="btn btn-outline-secondary">
                    Volver
                </a>
            </div>

        </div>
    </div>
</div>