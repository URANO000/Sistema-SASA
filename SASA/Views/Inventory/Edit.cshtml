@model DataAccess.Modelos.Entidades.Inventario.ActivoInventario

@{
    ViewData["Title"] = "Editar Activo";
}

<div class="container-fluid">

    <div class="card shadow-sm">
        <div class="card-body">

            <div class="mb-4">
                <h4 class="mb-0">Editar Activo</h4>
                <small class="text-muted">
                    Actualice la información de un activo existente.
                </small>
            </div>

            <form asp-action="Edit" asp-route-id="@Model.IdActivo" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="IdActivo" />

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Código del Activo</label>
                        <input type="text" class="form-control" value="@Model.NumeroActivo" readonly>
                    </div>

                    <div class="col-md-8">
                        <label asp-for="NombreMaquina" class="form-label">Nombre del Activo</label>
                        <input asp-for="NombreMaquina" type="text" class="form-control">
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="IdTipoActivo" class="form-label">Tipo de Activo</label>
                        <select asp-for="IdTipoActivo" asp-items="ViewBag.Tipos" class="form-select"></select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="IdEstadoActivo" class="form-label">Estado</label>
                        <select asp-for="IdEstadoActivo" asp-items="ViewBag.Estados" class="form-select"></select>
                    </div>
                </div>

                <!-- Opcionales (puedes quitar los que no quieras editar en Sprint 1) -->
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label asp-for="Marca" class="form-label">Marca</label>
                        <input asp-for="Marca" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Modelo" class="form-label">Modelo</label>
                        <input asp-for="Modelo" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="SerieServicio" class="form-label">Serie / Service Tag</label>
                        <input asp-for="SerieServicio" class="form-control" />
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="DireccionMAC" class="form-label">Dirección MAC</label>
                        <input asp-for="DireccionMAC" class="form-control" placeholder="AA:BB:CC:11:22:33" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SistemaOperativo" class="form-label">Sistema Operativo</label>
                        <input asp-for="SistemaOperativo" class="form-control" placeholder="Windows 11" />
                    </div>
                </div>

                <div class="d-flex justify-content-end">
                    <a asp-controller="Inventory"
                       asp-action="Detail"
                       asp-route-id="@Model.IdActivo"
                       class="btn btn-outline-secondary me-2">
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-primary">
                        Guardar Cambios
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>
