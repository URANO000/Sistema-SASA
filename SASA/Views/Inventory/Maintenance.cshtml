@model SASA.ViewModels.Inventario.MantenimientoIndexViewModel

@{
    ViewData["Title"] = "Historial de Mantenimiento";

    string BuildUrl(int pageNumber)
        => Url.Action("Maintenance", "Inventory", new
        {
            pageNumber = pageNumber,
            pageSize = Model.PageSize
        })!;
}

<div class="card">
    <div class="card-body">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h4 class="mb-1 fw-bold">Historial y Mantenimiento</h4>
                <p class="text-muted mb-0">
                    Registro de mantenimientos y reparaciones realizadas a los activos.
                </p>
            </div>

            <a asp-action="CreateMaintenance" class="btn btn-custom">
                <i class="bi bi-plus-lg"></i>
                Registrar Mantenimiento
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 90px;">Acciones</th>
                        <th>Activo</th>
                        <th>Fecha</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                        <th>Descripción</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <button type="button"
                                            class="btn btn-link p-0 me-2"
                                            title="Editar mantenimiento"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editMaintenanceModal"
                                            data-id="@item.IdMantenimiento">
                                        <i class="fa-regular fa-pen-to-square edit-btn"></i>
                                    </button>
                                </td>

                                <td>
                                    <div class="fw-semibold">@item.NumeroActivo</div>
                                    <div class="text-muted small">
                                        @(string.IsNullOrWhiteSpace(item.NombreMaquina) ? "-" : item.NombreMaquina)
                                    </div>
                                </td>

                                <td>@item.FechaMantenimiento.ToString("dd/MM/yyyy")</td>
                                <td>@item.TipoMantenimiento</td>

                                <td>
                                    @if (item.Estado == "Finalizado")
                                    {
                                        <span class="badge bg-success">Finalizado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">En proceso</span>
                                    }
                                </td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(item.Descripcion) ? "-" : item.Descripcion)
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No hay registros de mantenimiento disponibles.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 mt-3">
            <div class="text-muted small">
                Página <strong>@Model.PageNumber</strong> de <strong>@Model.TotalPages</strong>
            </div>

            <nav aria-label="Paginación de mantenimiento">
                <ul class="pagination mb-0">
                    <li class="page-item @(!Model.HasPrev ? "disabled" : "")">
                        <a class="page-link"
                               href="@(!Model.HasPrev ? "#" : BuildUrl(Model.PageNumber - 1))">
                            Anterior
                        </a>
                    </li>

                    <li class="page-item active">
                        <span class="page-link">@Model.PageNumber</span>
                    </li>

                    <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                        <a class="page-link"
                               href="@(!Model.HasNext ? "#" : BuildUrl(Model.PageNumber + 1))">
                            Siguiente
                        </a>
                    </li>
                </ul>
            </nav>
        </div>

        <div class="modal fade" id="editMaintenanceModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content" id="editMaintenanceModalContent">
                    <div class="modal-body text-center p-4 text-muted">
                        Cargando...
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const editMaintenanceModal = document.getElementById('editMaintenanceModal');
        const editMaintenanceContent = document.getElementById('editMaintenanceModalContent');

        function wireEditMaintenanceForm(id) {
            if (window.jQuery && jQuery.validator && jQuery.validator.unobtrusive) {
                jQuery.validator.unobtrusive.parse(editMaintenanceContent);
            }

            const form = document.getElementById("editMaintenanceForm");
            if (!form) return;

            form.addEventListener("submit", function (e) {
                e.preventDefault();

                const formData = new FormData(form);

                fetch(`/Inventory/EditMaintenanceModal?id=${id}`, {
                    method: "POST",
                    body: formData,
                    headers: { "X-Requested-With": "XMLHttpRequest" },
                    credentials: "same-origin"
                })
                .then(async r => {
                    const ct = r.headers.get("content-type") || "";

                    if (ct.includes("application/json")) {
                        const data = await r.json();
                        if (data.success) {
                            bootstrap.Modal.getOrCreateInstance(editMaintenanceModal).hide();
                            window.location.reload();
                            return;
                        }
                    }

                    const html = await r.text();
                    editMaintenanceContent.innerHTML = html;
                    wireEditMaintenanceForm(id);
                })
                .catch(() => {
                    editMaintenanceContent.innerHTML = `
                        <div class="modal-body p-4">
                            <div class="alert alert-danger mb-0">
                                Error guardando cambios.
                            </div>
                        </div>`;
                });
            }, { once: true });
        }

        editMaintenanceModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');

            editMaintenanceContent.innerHTML = `<div class="modal-body text-center p-4 text-muted">Cargando...</div>`;

            fetch(`/Inventory/EditMaintenanceModal?id=${id}`, { credentials: "same-origin" })
                .then(r => {
                    if (!r.ok) throw new Error("No se pudo cargar el mantenimiento.");
                    return r.text();
                })
                .then(html => {
                    editMaintenanceContent.innerHTML = html;
                    wireEditMaintenanceForm(id);
                })
                .catch(() => {
                    editMaintenanceContent.innerHTML = `
                        <div class="modal-body p-4">
                            <div class="alert alert-danger mb-0">
                                Error cargando formulario.
                            </div>
                        </div>`;
                });
        });

        editMaintenanceModal.addEventListener('hidden.bs.modal', function () {
            editMaintenanceContent.innerHTML = `<div class="modal-body text-center p-4 text-muted">Cargando...</div>`;
        });
    </script>
}