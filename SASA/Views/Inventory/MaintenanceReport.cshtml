@model SASA.ViewModels.Inventario.MantenimientoIndexViewModel

@{
    ViewData["Title"] = "Reporte de Mantenimiento";

    string BuildUrl(int pageNumber)
        => Url.Action("MaintenanceReport", "Inventory", new
        {
            pageNumber = pageNumber,
            pageSize = Model.PageSize
        })!;
}

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-body">

            <h4 class="fw-bold mb-1">Reporte de Mantenimiento</h4>
            <p class="text-muted mb-4">
                Detalle de mantenimientos realizados a los activos.
            </p>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Activo</th>
                            <th>Fecha</th>
                            <th>Tipo</th>
                            <th>Estado</th>
                            <th>Descripción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items != null && Model.Items.Any())
                        {
                            foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@item.NumeroActivo</div>
                                        <div class="text-muted small">@item.NombreMaquina</div>
                                    </td>
                                    <td>@item.FechaMantenimiento.ToString("dd/MM/yyyy")</td>
                                    <td>@item.TipoMantenimiento</td>
                                    <td>
                                        @if (item.Estado == "Finalizado")
                                        {
                                            <span class="badge bg-success">Finalizado</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">En proceso</span>
                                        }
                                    </td>
                                    <td>@(string.IsNullOrWhiteSpace(item.Descripcion) ? "-" : item.Descripcion)</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    No hay datos de mantenimiento para mostrar.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 mt-3">
                <div class="text-muted small">
                    Página <strong>@Model.PageNumber</strong> de <strong>@Model.TotalPages</strong>
                </div>

                <nav aria-label="Paginación reporte mantenimiento">
                    <ul class="pagination mb-0">
                        <li class="page-item @(!Model.HasPrev ? "disabled" : "")">
                            <a class="page-link"
                                   href="@(!Model.HasPrev ? "#" : BuildUrl(Model.PageNumber - 1))">
                                Anterior
                            </a>
                        </li>

                        <li class="page-item active">
                            <span class="page-link">@Model.PageNumber</span>
                        </li>

                        <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                            <a class="page-link"
                                   href="@(!Model.HasNext ? "#" : BuildUrl(Model.PageNumber + 1))">
                                Siguiente
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>

            <div class="d-flex justify-content-end mt-3">
                <a asp-action="Reports" class="btn btn-outline-secondary">
                    Volver
                </a>
            </div>

        </div>
    </div>
</div>