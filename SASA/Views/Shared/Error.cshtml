@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="card sasa-card shadow-sm" style="max-width: 500px; width: 100%;">
        <div class="card-body text-center p-4">

            <div class="mb-3">
                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 2.5rem;"></i>
            </div>

            <h2 class="text-danger fw-bold mb-2">Algo salió mal</h2>

            <p class="text-muted mb-3">
                Ha ocurrido un error. Estamos trabajando para solucionarlo lo antes posible.
            </p>

            <div class="d-grid gap-2">
                <a asp-action="Index" asp-controller="Home" class="btn btn-primary">
                    Volver al inicio
                </a>
                <a href="javascript:history.back()" class="btn btn-outline-secondary">
                    Regresar
                </a>
            </div>

        </div>
    </div>
</div>