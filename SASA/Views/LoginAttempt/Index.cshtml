@model SASA.ViewModels.Auth.LoginAttemptIndexViewModel

@{
    ViewData["Title"] = "Historial de intentos de inicio de sesión";
}

<div class="card mb-4">
    <div class="card-body">
        <div class="ticket-header mb-4">
            <div class="d-flex justify-content-between align-items-center mt-2">
                <h4 class="mb-0 fw-bold">Historial de intentos de inicio de sesión</h4>

                <span class="badge bg-secondary">
                    Total: @Model.TotalCount
                </span>
            </div>
        </div>

        <h6 class="section-title">Filtros de búsqueda</h6>

        <form method="get" asp-controller="LoginAttempt" asp-action="Index" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Correo ingresado</label>
                <input asp-for="Filtros.EmailIngresado" class="form-control" placeholder="Ej: usuario@correo.com" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Resultado</label>
                <select name="Filtros.Exitoso" class="form-select">
                    @if (Model.Filtros.Exitoso == null)
                    {
                        <option value="" selected>Todos</option>
                        <option value="true">Exitoso</option>
                        <option value="false">Fallido</option>
                    }
                    else if (Model.Filtros.Exitoso == true)
                    {
                        <option value="">Todos</option>
                        <option value="true" selected>Exitoso</option>
                        <option value="false">Fallido</option>
                    }
                    else
                    {
                        <option value="">Todos</option>
                        <option value="true">Exitoso</option>
                        <option value="false" selected>Fallido</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Fecha desde</label>
                <input asp-for="Filtros.FechaDesde" type="date" class="form-control" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Fecha hasta</label>
                <input asp-for="Filtros.FechaHasta" type="date" class="form-control" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Cantidad por página</label>
                <input asp-for="Filtros.PageSize" type="number" min="1" class="form-control" />
            </div>

            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive card">
    @if (Model.Items == null || !Model.Items.Any())
    {
        <div class="card-body">
            <div class="alert alert-info mb-0">
                No se encontraron intentos de inicio de sesión con los filtros seleccionados.
            </div>
        </div>
    }
    else
    {
        <table class="table table-hover align-middle sasa-table mb-0">
            <thead>
                <tr>
                    <th>Fecha UTC</th>
                    <th>Correo ingresado</th>
                    <th>Tipo de cuenta</th>
                    <th>Resultado</th>
                    <th>Motivo fallo</th>
                    <th>IP</th>
                    <th>User Agent</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.FechaUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@item.EmailIngresado</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(item.UserId))
                            {
                                <span class="badge bg-secondary">No registrada</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark">Registrada</span>
                            }
                        </td>
                        <td>
                            @if (item.Exitoso)
                            {
                                <span class="badge bg-success">Exitoso</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Fallido</span>
                            }
                        </td>
                        <td>
                            @{
                                string motivo = item.MotivoFallo ?? "";
                                motivo = motivo switch
                                {
                                    "InvalidCredentials" => "Credenciales inválidas",
                                    "UserNotFound" => "Usuario no existe",
                                    "LockedOut" => "Bloqueo temporal",
                                    "NotAllowed" => "No permitido",
                                    "Disabled" => "Cuenta desactivada",
                                    _ => (string.IsNullOrWhiteSpace(motivo) ? "-" : motivo)
                                };
                            }
                            @motivo
                        </td>
                        <td>
                            @{
                                var ipMostrar =
                                (item.IpAddress == "::1" || item.IpAddress == "127.0.0.1")
                                ? "Localhost"
                                : (string.IsNullOrWhiteSpace(item.IpAddress) ? "-" : item.IpAddress);
                            }
                            <span class="badge bg-light text-dark">@ipMostrar</span>
                        </td>
                        <td style="max-width: 320px; word-break: break-word;">
                            @(string.IsNullOrWhiteSpace(item.UserAgent) ? "-" : item.UserAgent)
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Paginación" class="align-content-center justify-content-center mt-3 mb-3">
                <ul class="pagination pagination-sm mb-0 justify-content-center">

                    <li class="page-item @(Model.Filtros.Page > 1 ? "" : "disabled")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-Filtros.EmailIngresado="@Model.Filtros.EmailIngresado"
                               asp-route-Filtros.Exitoso="@Model.Filtros.Exitoso"
                               asp-route-Filtros.FechaDesde="@(Model.Filtros.FechaDesde?.ToString("yyyy-MM-dd"))"
                               asp-route-Filtros.FechaHasta="@(Model.Filtros.FechaHasta?.ToString("yyyy-MM-dd"))"
                               asp-route-Filtros.Page="@(Model.Filtros.Page - 1)"
                               asp-route-Filtros.PageSize="@Model.Filtros.PageSize">
                            Anterior
                        </a>
                    </li>

                    <li class="page-item disabled">
                        <span class="page-link">
                            Página @Model.Filtros.Page de @Model.TotalPages
                        </span>
                    </li>

                    <li class="page-item @(Model.Filtros.Page < Model.TotalPages ? "" : "disabled")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-Filtros.EmailIngresado="@Model.Filtros.EmailIngresado"
                               asp-route-Filtros.Exitoso="@Model.Filtros.Exitoso"
                               asp-route-Filtros.FechaDesde="@(Model.Filtros.FechaDesde?.ToString("yyyy-MM-dd"))"
                               asp-route-Filtros.FechaHasta="@(Model.Filtros.FechaHasta?.ToString("yyyy-MM-dd"))"
                               asp-route-Filtros.Page="@(Model.Filtros.Page + 1)"
                               asp-route-Filtros.PageSize="@Model.Filtros.PageSize">
                            Siguiente
                        </a>
                    </li>

                </ul>
            </nav>
        }
    }
</div>

