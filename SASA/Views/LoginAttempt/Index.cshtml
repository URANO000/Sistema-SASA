@model SASA.ViewModels.Auth.LoginAttemptIndexViewModel

@{
    ViewData["Title"] = "Historial de intentos de inicio de sesión";
}

<div class="container-fluid">
    <div class="card mb-3">
        <div class="card-body">

            <div class="mb-3">
                <h2 class="mb-0 fw-bold">Gestión de Intentos de Inicio de Sesión</h2>
            </div>

            <form method="get" asp-controller="LoginAttempt" asp-action="Index">
                <input type="hidden" name="Filtros.Page" value="1" />
                <input type="hidden" name="Filtros.PageSize" value="@Model.Filtros.PageSize" />

                <div class="row g-2 align-items-end mb-3">
                    <div class="col-12 col-md-4">
                        <label class="form-label">Buscar por correo ingresado</label>
                        <input asp-for="Filtros.EmailIngresado"
                               class="form-control"
                               placeholder="Ej: usuario@correo.com" />
                    </div>

                    <div class="col-12 col-md-2">
                        <label class="form-label">Resultado</label>
                        <select name="Filtros.Exitoso" class="form-select">
                            <option value="" selected="@(Model.Filtros.Exitoso == null)">Todos</option>
                            <option value="true" selected="@(Model.Filtros.Exitoso == true)">Exitoso</option>
                            <option value="false" selected="@(Model.Filtros.Exitoso == false)">Fallido</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label mb-0" id="main-label">Fecha</label>

                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" id="dateRangeSwitch">
                                <label class="form-check-label small ms-1" for="dateRangeSwitch">Rango</label>
                            </div>
                        </div>

                        <div id="single-wrapper">
                            <input type="date"
                                   class="form-control"
                                   name="Filtros.Fecha"
                                   id="filter-date-single"
                                   value="@(Model.Filtros.Fecha?.ToString("yyyy-MM-dd"))">
                        </div>

                        <div class="row g-2 d-none" id="range-wrapper">
                            <div class="col-12 col-sm-6">
                                <label class="form-label mb-1 small">Fecha Inicio</label>
                                <input type="date"
                                       class="form-control"
                                       name="Filtros.FechaDesde"
                                       id="filter-date-from"
                                       value="@(Model.Filtros.FechaDesde?.ToString("yyyy-MM-dd"))"
                                       disabled>
                            </div>

                            <div class="col-12 col-sm-6">
                                <label class="form-label mb-1 small">Fecha Fin</label>
                                <input type="date"
                                       class="form-control"
                                       name="Filtros.FechaHasta"
                                       id="filter-date-to"
                                       value="@(Model.Filtros.FechaHasta?.ToString("yyyy-MM-dd"))"
                                       disabled>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-2">
                        <button type="submit" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-funnel"></i>
                            Filtrar
                        </button>
                    </div>
                </div>
            </form>

            @if (Model.Items == null || !Model.Items.Any())
            {
                <div class="alert alert-info mb-0">
                    No se encontraron intentos de inicio de sesión con los filtros seleccionados.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle sasa-table login-attempts-table">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Correo</th>
                                <th>Resultado</th>
                                <th class="d-none d-lg-table-cell">Tipo de cuenta</th>
                                <th class="d-none d-lg-table-cell">Motivo fallo</th>
                                <th class="d-none d-lg-table-cell">IP</th>
                                <th class="d-none d-lg-table-cell">User Agent</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.FechaUtc.ToString("yyyy-MM-dd")<br />@item.FechaUtc.ToString("HH:mm:ss")</td>
                                    <td>@item.EmailIngresado</td>

                                    <td>
                                        @if (item.Exitoso)
                                        {
                                            <span class="badge bg-success">Exitoso</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Fallido</span>
                                        }
                                    </td>

                                    <td class="d-none d-lg-table-cell">
                                        @if (string.IsNullOrWhiteSpace(item.UserId))
                                        {
                                            <span class="badge bg-secondary">No registrada</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info text-dark">Registrada</span>
                                        }
                                    </td>
                                    <td class="d-none d-lg-table-cell">
                                        @{
                                            string motivo = item.MotivoFallo ?? "";
                                            motivo = motivo switch
                                            {
                                                "InvalidCredentials" => "Credenciales inválidas",
                                                "UserNotFound" => "Usuario no existe",
                                                "LockedOut" => "Bloqueo temporal",
                                                "NotAllowed" => "No permitido",
                                                "Disabled" => "Cuenta desactivada",
                                                _ => (string.IsNullOrWhiteSpace(motivo) ? "-" : motivo)
                                            };
                                        }
                                        @motivo
                                    </td>
                                    <td class="d-none d-lg-table-cell">
                                        @{
                                            var ipMostrar =
                                            (item.IpAddress == "::1" || item.IpAddress == "127.0.0.1")
                                            ? "Localhost"
                                            : (string.IsNullOrWhiteSpace(item.IpAddress) ? "-" : item.IpAddress);
                                        }
                                        <span class="badge bg-light text-dark">@ipMostrar</span>
                                    </td>
                                    <td class="d-none d-lg-table-cell user-agent-cell">
                                        @(string.IsNullOrWhiteSpace(item.UserAgent) ? "-" : item.UserAgent)
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <nav aria-label="Paginación" class="mt-2">
                <ul class="pagination pagination-sm mb-0 justify-content-center">

                    <!-- Previous -->
                    <li class="page-item @(Model.TieneAnterior ? "" : "disabled")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-Filtros.EmailIngresado="@Model.Filtros.EmailIngresado"
                           asp-route-Filtros.Exitoso="@Model.Filtros.Exitoso"
                           asp-route-Filtros.Fecha="@(Model.Filtros.Fecha?.ToString("yyyy-MM-dd"))"
                           asp-route-Filtros.FechaDesde="@(Model.Filtros.FechaDesde?.ToString("yyyy-MM-dd"))"
                           asp-route-Filtros.FechaHasta="@(Model.Filtros.FechaHasta?.ToString("yyyy-MM-dd"))"
                           asp-route-Filtros.Page="@(Model.Filtros.Page - 1)"
                           asp-route-Filtros.PageSize="@Model.Filtros.PageSize">
                            Anterior
                        </a>
                    </li>

                    <!-- Info -->
                    <li class="page-item disabled">
                        <span class="page-link">
                            Página @Model.Filtros.Page de @Model.TotalPages
                        </span>
                    </li>

                    <!-- Next -->
                    <li class="page-item @(Model.TieneSiguiente ? "" : "disabled")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-Filtros.EmailIngresado="@Model.Filtros.EmailIngresado"
                           asp-route-Filtros.Exitoso="@Model.Filtros.Exitoso"
                           asp-route-Filtros.Fecha="@(Model.Filtros.Fecha?.ToString("yyyy-MM-dd"))"
                           asp-route-Filtros.FechaDesde="@(Model.Filtros.FechaDesde?.ToString("yyyy-MM-dd"))"
                           asp-route-Filtros.FechaHasta="@(Model.Filtros.FechaHasta?.ToString("yyyy-MM-dd"))"
                           asp-route-Filtros.Page="@(Model.Filtros.Page + 1)"
                           asp-route-Filtros.PageSize="@Model.Filtros.PageSize">
                            Siguiente
                        </a>
                    </li>

                </ul>
            </nav>

        </div>
    </div>
</div>

