@{
    ViewData["Title"] = "Gestión de Colas de Trabajo";
}

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<div class="container py-4 sasa-card">

    <h4 class="mb-4 fw-bold">Cola de Tiquetes</h4>

    <div id="ticketQueue" class="notif-list">

        <div class="notif-item notif-unread" data-id="1">
            <div class="notif-body">
                <div class="queue-position">#1</div>

                <div>
                    <div class="ticket-title">Printer not working</div>
                    <div class="ticket-meta">
                        Hardware • High Priority
                    </div>
                </div>
            </div>

            <span class="badge bg-warning text-dark">In Progress</span>
        </div>

        <div class="notif-item notif-unread" data-id="2">
            <div class="notif-body">
                <div class="queue-position">#2</div>

                <div>
                    <div class="ticket-title">Email login issue</div>
                    <div class="ticket-meta">
                        Software • Medium Priority
                    </div>
                </div>
            </div>

            <span class="badge bg-secondary">Open</span>
        </div>

        <div class="notif-item notif-unread" data-id="3">
            <div class="notif-body">
                <div class="queue-position">#3</div>

                <div>
                    <div class="ticket-title">VPN connection failing</div>
                    <div class="ticket-meta">
                        Network • Medium Priority
                    </div>
                </div>
            </div>

            <span class="badge bg-secondary">Open</span>
        </div>

    </div>

</div>


@section Scripts {
    <script src="~/js/Queue.js" asp-append-version="true"></script>
}