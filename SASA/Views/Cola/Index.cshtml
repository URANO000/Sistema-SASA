@using SASA.ViewModels.Tiquete.Cola
@model ColaIndexViewModel
@{
    ViewData["Title"] = "Gestión de Colas de Trabajo";
    var tabColaPersonalActiva = Model.TabActiva == "Cola Personal";
    var tabColaGlobalActiva = Model.TabActiva == "Cola Global";
}

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<div class="container-fluid">
    <div class="card mb-3">
        <div class="card-body">
            <div class="">
                <h2 class="mb-4 fw-bold">Colas de Trabajo</h2>


                <ul class="nav nav-tabs mb-3" id="categoriaTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(tabColaPersonalActiva ? "active" : "")"
                                id="personal-tab"
                                data-bs-toggle="tab"
                                data-bs-target="#personal-pane"
                                type="button"
                                role="tab">
                                Cola Personal
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(tabColaGlobalActiva ? "active" : "")"
                                id="global-tab"
                                data-bs-toggle="tab"
                                data-bs-target="#global-pane"
                                type="button"
                                role="tab">
                                Cola Global
                        </button>
                    </li>
                </ul>

                <div class="tab-content" id="colaTabsContent">
                    <div class="tab-pane fade @(tabColaPersonalActiva ? "show active" : "")" id="personal-pane" role="tabpanel">
                        <div id="ticketQueue" class="notif-list queue-container" style="max-height: 700px; overflow-y: auto; overflow-x: auto;">

                            @foreach (var c in Model.Personal)
                            {
                                <div class="notif-item notif-unread ticket-card"
                                    data-id="@c.IdTiquete"
                                    data-orden="@c.OrdenCola">
                                    <div class="notif-left">
                                        <div class="notif-icon info">
                                            #@c.PosicionCola
                                        </div>
                                    </div>
                                    <div class="notif-body">
                                       <div class="notif-row">
                                            <div>
                                                <div class="notif-title">@c.Asunto</div>
                                                <div class="notif-meta">
                                                    <ul class="list-unstyled">

                                                            <li class="text-muted small">
                                                                Categoría : @c.Categoria
                                                            </li>

                                                            <li class="mt-2 d-flex gap-2 flex-wrap">

                                                                <!-- PRIORITY -->
                                                                @switch (c.Prioridad)
                                                                {
                                                                    case "Baja":
                                                                        <span class="badge bg-secondary">Baja</span>
                                                                        break;
                                                                    case "Media":
                                                                        <span class="badge bg-primary">Media</span>
                                                                        break;
                                                                    case "Alta":
                                                                        <span class="badge bg-warning text-dark">Alta</span>
                                                                        break;
                                                                    default:
                                                                        <span class="badge bg-danger">Crítica</span>
                                                                        break;
                                                                }

                                                                <!-- TIME -->
                                                                @if (!c.EstaAtrasado)
                                                                {
                                                                    <span class="badge bg-success">
                                                                        @c.TiempoRestante
                                                                    </span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge bg-danger">
                                                                        +@c.TiempoExcedido
                                                                    </span>
                                                                }

                                                            </li>
                                                    </ul>
                                                </div>
                                            </div>
                                       </div>
                                    </div>
                                </div>
                            }

                        </div>
                    </div>

                    <div class="tab-pane fade @(tabColaGlobalActiva ? "show active" : "")" id="global-pane" role="tabpanel">

                        <!-- Kanban Board Container -->
                        <div class="kanban-board d-flex gap-3 p-2">

                            @foreach (var assignee in Model.Global)
                            {
                                <div class="kanban-column card shadow-sm">

                                    <!-- Column Header -->
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <span class="fw-bold">@assignee.AssigneeNombre</span>

                                        <small class="badge-ticket-num">
                                            @assignee.Colas.Count @(assignee.Colas.Count == 1 ? "tiquete" : "tiquetes")
                                        </small>
                                    </div>

                                    <!-- Column Body (Scrollable) -->
                                    <div class="kanban-body">

                                        @foreach (var c in assignee.Colas)
                                        {
                                            <div class="kanban-card">

                                                <div class="kanban-card-header">
                                                    <span class="badge bg-secondary">#@c.PosicionCola</span>
                                                </div>

                                                <div class="kanban-card-body">
                                                    <div class="fw-semibold">@c.Asunto</div>

                                                    <small class="text-muted d-block">
                                                         @c.Categoria
                                                    </small>

                                                    <small class="text-muted d-block mb-2">
                                                        Prioridad: @c.Prioridad
                                                    </small>

                                                    <a asp-route-id="@c.IdTiquete"
                                                           class="btn btn-sm btn-custom w-100"
                                                           asp-action="Details"
                                                           asp-controller="Tiquete">
                                                        Ver
                                                    </a>
                                                </div>

                                            </div>
                                        }

                                    </div>
                                </div>
                            }

                        </div>
                    </div>
                </div>
           </div>
        </div>
    </div>

</div>

@functions {
    private string FormatearTiempo(DateTime fecha)
    {
        var f = fecha;

        var hoy = DateTime.Now.Date;
        var ayer = hoy.AddDays(-1);

        if (f.Date == hoy)
            return $"Hoy • {f:HH:mm}";

        if (f.Date == ayer)
            return $"Ayer • {f:HH:mm}";

        return $"{f:yyyy-MM-dd} • {f:HH:mm}";
    }
}

@section Scripts {
    <script src="~/js/Queue.js" asp-append-version="true"></script>
}

