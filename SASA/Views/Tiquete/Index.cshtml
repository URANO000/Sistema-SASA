@using SASA.ViewModels.Tiquete;
@model IReadOnlyList<TiqueteListaViewModel>

@{
    ViewData["Title"] = "Gestión de Tiquetes";
}
<div class="container-fluid">
    <!-- Header -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="mb-0 fw-bold">Gestión de Tiquetes</h2>
                <button class="btn btn-custom" id="openCreateModal">
                    <i class="bi bi-plus-lg"></i>
                    Nuevo Tiquete
                </button>
            </div>
            <!-- Filters -->
            <div class="row g-2 align-items-end mb-3">
                <div class="col-md-4">
                    <label class="form-label">Buscar</label>
                    <input type="text" class="form-control" placeholder="Código o asunto">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Estado</label>
                    <select class="form-select">
                        <option value="">Todos</option>
                        <option>Abierto</option>
                        <option>En Progreso</option>
                        <option>Cancelado</option>
                        <option>Resuelto</option>
                        <option>Cerrado</option>

                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Prioridad</label>
                    <select class="form-select">
                        <option value="">Todas</option>
                        <option>Alta</option>
                        <option>Media</option>
                        <option>Baja</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha</label>
                    <input type="date" class="form-control">
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100">
                        <i class="bi bi-funnel"></i>
                        Filtrar
                    </button>
                </div>
            </div>
            <!-- Table -->
            <div class="table-responsive">
                <table class="table table-hover align-middle sasa-table">
                    <thead class="">
                        <tr>
                            <th>Acciones</th>
                            <th>Id</th>
                            <th>Asunto</th>
                            <th>Estatus</th>
                            <th>Prioridad</th>
                            <th>Categoría</th>
                            <th>Cola</th>
                            <th>Creado Por</th>
                            <th>Fecha de Creación</th>
                            <th>Asignado</th>
                            <th>Fecha de Edición</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model)
                        {
                            <tr>
                                <td>
                                    <a class="btn btn-link icon-btn" asp-area=""
                                       asp-controller="Tiquete"
                                       asp-action="Details"
                                       asp-route-id="@t.IdTiquete">
                                        <i class="bi bi-eye detail-btn"></i>
                                    </a>
                                    <a class="btn btn-link icon-btn" asp-area=""
                                       asp-controller="Tiquete"
                                       asp-action="Edit"
                                       asp-route-id="@t.IdTiquete">
                                        <i class="fa-regular fa-pen-to-square edit-btn"></i>
                                    </a>
                                </td>

                                <td>@t.IdTiquete</td>
                                <td>@t.Asunto</td>
                                @switch (t.Estatus)
                                {
                                    case "Abierto":
                                        <td>
                                            <span class="badge bg-primary">@t.Estatus</span>
                                        </td>
                                        break;
                                    case "En Progreso":
                                        <td>
                                            <span class="badge bg-warning">@t.Estatus</span>
                                        </td>
                                        break;
                                    case "Cancelado":
                                        <td>
                                            <span class="badge bg-danger">@t.Estatus</span>
                                        </td>
                                        break;
                                    case "Resuelto":
                                        <td>
                                            <span class="badge bg-success"> @t.Estatus </span>
                                        </td>
                                        break;
                                    default:
                                        <td>
                                            <span class="badge bg-secondary"> @t.Estatus </span>
                                        </td>
                                        break;
                                }

                                <td>@t.Prioridad</td>
                                <td>@t.Categoria</td>
                                <td>@t.Cola</td>
                                <td>@t.ReportedBy</td>
                                <td>@t.CreatedAt</td>
                                <td>@t.Asignee</td>
                                <td>@t.UpdatedAt</td>
                            </tr>
                        }

                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<div id="modalContainer"></div>

@await Html.PartialAsync("_SuccessModal")
@await Html.PartialAsync("_ErrorModal")


@section Scripts {
    <script src="~/js/formSubmits.js" asp-append-version="true"></script>
    <script>
        $(document).on('click', '#openCreateModal', function () {

        $.get('/Tiquete/Add', function (data) {

            $('#modalContainer').html(data);

            const form = $("#crearTiqueteForm");

            form.removeData("validator");
            form.removeData("unobtrusiveValidation");

            $.validator.unobtrusive.parse(form);

            const modalElement = document.getElementById('addTicketModal');
            const modal = new bootstrap.Modal(modalElement);

            modal.show();
        });


        });
    </script>
}
