@using SASA.ViewModels.Tiquete
@model TiqueteDetalleViewModel
@{
    ViewData["Title"] = "Detalle de Tiquete";
}

<!---------Make sure to always keep separation of important and slightly less important-------->
<div class="card mb-3">
    <div class="card-body">
        <div class="ticket-header mb-4">
            <a asp-area="" asp-controller="Tiquete" asp-action="Index" class="btn btn-link px-0">
                <i class="bi bi-arrow-left"></i> Volver al listado
            </a>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <h4 class="mb-0 fw-bold">Tiquete @Model.IdTiquete</h4>
                @switch (Model.Estatus)
                {
                    case "Abierto":
                            <span class="badge bg-primary">@Model.Estatus</span>
                        break;
                    case "En Progreso":
                            <span class="badge bg-warning">@Model.Estatus</span>
                        break;
                    case "Cancelado":
                            <span class="badge bg-danger">@Model.Estatus</span>
                        break;
                    case "Resuelto":
                            <span class="badge bg-success"> @Model.Estatus </span>
                        break;
                    default:
                            <span class="badge bg-secondary"> @Model.Estatus </span>
                        break;
                }
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- MAIN -->
    <div class="col-lg-8">
        <!-- Description -->
        <div class="card mb-4">
            <div class="card-body">
                <h6 class="section-title">Asunto</h6>
                <p class="text-muted mb-0">
                    @Model.Asunto
                </p>
                <h6 class="section-title">Descripción</h6>
                <p class="text-muted mb-0">
                    @Model.Descripcion
                </p>
            </div>
        </div>

        <!-- Info general -->
        <div class="card mb-4">
            <div class="card-body">
                <h6 class="section-title">Información del Tiquete</h6>

                <dl class="row mb-0">
@*                     <dt class="col-5">Prioridad</dt>
                    <dd class="col-7">@Model.Prioridad</dd> *@

                    <dt class="col-5">Creado por</dt>
                    <dd class="col-7">@Model.ReportedBy</dd>

                    <dt class="col-5">Departamento</dt>
                    <dd class="col-7">@Model.Departamento</dd>

                    <dt class="col-5">Agente Asignado</dt>
                    <dd class="col-7">@Model.Asignee</dd>

                    <dt class="col-5">Fecha creación</dt>
                    <dd class="col-7">@Model.CreatedAt</dd>

                    <dt class="col-5">Última actualización</dt>
                    @if(Model.UpdatedAt != null)
                    {
                        <dd class="col-7">@Model.UpdatedAt</dd>
                    }
                    else
                    {
                        <dd class="col-7">Sin Actualizar</dd>
                    }
                    </dl>
            </div>
        </div>

        <!-- Attachments -->
        <div class="card">
            <div class="card-body">
                <h6 class="section-title">Documentos Adjuntos</h6>

                <ul class="list-unstyled">
                    <li>
                        <i class="bi bi-paperclip"></i>
                        <a href="#">diagnostico-red.pdf</a>
                    </li>
                    <li>
                        <i class="bi bi-paperclip"></i>
                        <a href="#">foto-equipo.jpg</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- SIDE - Timeline-->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-body">
               
                <h6 class="section-title">Historial y Avances</h6>

                <ul class="timeline">
                    <li>
                        <span class="timeline-date">12/03/2025 09:14</span>
                        <p><strong>Creado</strong> por Juan Pérez</p>
                    </li>
                    <li>
                        <span class="timeline-date">12/03/2025 10:02</span>
                        <p>Asignado a Soporte TI</p>
                    </li>
                    <li>
                        <span class="timeline-date">12/03/2025 14:30</span>
                        <p>Diagnóstico inicial completado</p>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
