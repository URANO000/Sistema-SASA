@using SASA.ViewModels.Tiquete.UsuarioNormal
@model CrearTiqueteUsuarioViewModel
<div class="modal fade" id="addTicket" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <form asp-action="Add"
                  asp-controller="Tiquete"
                  method="post"
                  id="crearTiqueteUserForm">

                @Html.AntiForgeryToken()

                <!-- Header -->
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-ticket-perforated me-2"></i>
                        Registrar Nuevo Tiquete
                    </h5>
                    <button type="button" class="btn-close icon-btn" data-bs-dismiss="modal"></button>
                </div>

                <!-- Body -->
                <div class="modal-body">
                    <div class="form-container">

                        <div class="form-content">
                            <p class="section-subtitle">
                                Complete los campos requeridos para registrar un tiquete.
                            </p>

                            <div class="row g-3">

                                <!-- Asunto -->
                                <div class="col-md-6">
                                    <label asp-for="Asunto" class="form-label required-field">Problema</label>
                                    <input asp-for="Asunto" type="text" class="form-control">
                                    <span asp-validation-for="Asunto" class="text-danger"></span>
                                </div>
                                <!-- Categoría -->
                                <div class="col-md-6">
                                    <label asp-for="Categoria" class="form-label required-field">Categoría</label>
                                    <select asp-for="Categoria"
                                            asp-items="Model.Categorias"
                                            class="form-select">
                                        <option value="" disabled>Seleccione una categoría</option>
                                    </select>
                                    <span asp-validation-for="Categoria" class="text-danger"></span>
                                </div>
                                <!-- Descripción -->
                                <div class="col-12">
                                    <label asp-for="Descripcion" class="form-label required-field">Descripción</label>
                                    <textarea asp-for="Descripcion" class="form-control" rows="4"
                                              placeholder="Describa el problema o solicitud"></textarea>
                                </div>
                                <span asp-validation-for="Descripcion" class="text-danger"></span>

                            </div>
                        </div>

                        <!-- Footer -->
                        <div class="modal-footer-custom">
                            <div class="d-flex justify-content-end gap-2">
                                <button type="button" class="btn btn-outline-secondary"
                                        data-bs-dismiss="modal">
                                    Cancelar
                                </button>
                                <button type="submit"
                                        class="btn btn-success text-white">
                                    Crear Tiquete
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
            </form>

        </div>
    </div>
</div>