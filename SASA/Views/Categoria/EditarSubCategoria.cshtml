@model SASA.ViewModels.Categoria.EditarSubCategoriaViewModel

@{
    ViewData["Title"] = "Editar Subcategoría";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-body">
            <h2 class="mb-4 fw-bold">Editar Subcategoría</h2>

            <form asp-action="EditarSubCategoria" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="IdSubCategoria" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="mb-3 col-md-6">
                        <label asp-for="IdCategoria" class="form-label required-field"></label>
                        <select asp-for="IdCategoria" asp-items="Model.Categorias" class="form-select"></select>
                        <span asp-validation-for="IdCategoria" class="text-danger"></span>
                    </div>

                    <div class="mb-3 col-md-6">
                        <label asp-for="IdPrioridad" class="form-label required-field"></label>
                        <select asp-for="IdPrioridad" asp-items="Model.Prioridades" class="form-select"></select>
                        <span asp-validation-for="IdPrioridad" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3 col-md-6">
                    <label asp-for="NombreSubCategoria" class="form-label required-field"></label>
                    <input asp-for="NombreSubCategoria" class="form-control" />
                    <span asp-validation-for="NombreSubCategoria" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-custom">Guardar cambios</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>