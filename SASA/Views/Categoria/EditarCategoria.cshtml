@model SASA.ViewModels.Categoria.EditarCategoriaViewModel

@{
    ViewData["Title"] = "Editar Categoría";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-body">
            <h2 class="mb-4 fw-bold">Editar Categoría</h2>

            <form asp-action="EditarCategoria" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="IdCategoria" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3 col-md-6">
                    <label asp-for="NombreCategoria" class="form-label required-field"></label>
                    <input asp-for="NombreCategoria" class="form-control" />
                    <span asp-validation-for="NombreCategoria" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-custom">Guardar cambios</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>