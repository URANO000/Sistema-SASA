@model SASA.ViewModels.Home.DashboardViewModel

@{
    ViewData["Title"] = "Inicio";
}

<div>
    <style>
        .dashboard-card { min-width: 200px; padding: 0.5rem; }
        .dashboard-card .card-body h3 { font-size: 1.9rem; }
    </style>
    <!-- Header -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="mb-0 fw-bold">Dashboard de Tiquetes</h2>
            </div>
        </div>
    </div>
    <div class="row g-3 mb-4 justify-content-center align-items-center">
        <div class="col-auto">
            <div class="card text-center dashboard-card">
                <div class="card-body">
                    <h6 class="text-muted">Abiertos</h6>
                    <h3 id="cardAbiertos" class="fw-bold text-primary">@Model.Abiertos</h3>
                </div>
            </div>
        </div>

        <div class="col-auto">
            <div class="card text-center dashboard-card">
                <div class="card-body">
                    <h6 class="text-muted">En Proceso</h6>
                    <h3 id="cardEnProgreso" class="fw-bold text-warning">@Model.EnProgreso</h3>
                </div>
            </div>
        </div>

        <div class="col-auto">
            <div class="card text-center dashboard-card">
                <div class="card-body">
                    <h6 class="text-muted">Resueltos</h6>
                    <h3 id="cardResueltos" class="fw-bold text-success">@Model.Resueltos</h3>
                </div>
            </div>
        </div>

        <div class="col-auto">
            <div class="card text-center dashboard-card">
                <div class="card-body">
                    <h6 class="text-muted">Cancelados</h6>
                    <h3 id="cardCancelados" class="fw-bold text-danger">@Model.Cancelados</h3>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card text-center dashboard-card">
                <div class="card-body">
                    <h6 class="text-muted">En Espera</h6>
                    <h3 id="cardEnEspera" class="fw-bold text-secondary">@Model.EnEsperaDelUsuario</h3>
                </div>
            </div>
        </div>
    </div>


    <!--Charts start coming in here, using the chart.js cdn located in Layout-->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h6 class="section-title">Tiquetes por Estado</h6>
                    <canvas id="estadoChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h6 class="section-title">Tiquetes por Prioridad</h6>
                    <canvas id="prioridadChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h6 class="section-title">Evolución de Tiquetes</h6>
                    <canvas id="trendChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>
    <script>
        //
        window.__dashboardInit = {
            Abiertos: @Model.Abiertos,
            EnProgreso: @Model.EnProgreso,
            Resueltos: @Model.Resueltos,
            Cancelados: @Model.Cancelados,
            EnEsperaDelUsuario: @Model.EnEsperaDelUsuario,
            PriorityLabels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PriorityLabels)),
            PriorityCounts: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PriorityCounts)),
            PriorityDisplayLabels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PriorityDisplayLabels)),
            PriorityTicketCounts: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PriorityTicketCounts)),
            TrendLabels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrendLabels)),
            TrendAbiertos: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrendAbiertos)),
            TrendEspera: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrendEspera)),
            TrendCancelados: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrendCancelados)),
            TrendResueltos: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrendResueltos)),
            TrendEnProgreso: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrendEnProgreso))
        };
    </script>
    <script src="~/js/dashboard.js"></script>
