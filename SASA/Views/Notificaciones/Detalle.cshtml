@using DataAccess.Modelos.DTOs.Notificaciones
@model NotificacionDTO

@{
    ViewData["Title"] = "Detalle de notificación";
}

<div class="sasa-card">

    <div class="d-flex justify-content-between align-items-start gap-3">
        <div>
            <h2 class="mb-1">Detalle de notificación</h2>
            <div class="text-muted small">
                Notificación relacionada (ID: @Model.IdNotificacion)
            </div>
        </div>

        <a asp-controller="Notificaciones" asp-action="Index" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Volver
        </a>
    </div>

    <hr />

    <div class="notif-detail">
        <div class="notif-detail-row">
            <span class="label">Tipo</span>
            <span class="value">@Model.TipoEvento</span>
        </div>

        <div class="notif-detail-row">
            <span class="label">Fecha y hora</span>
            <span class="value">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
        </div>

        <div class="notif-detail-row">
            <span class="label">Mensaje</span>
            <span class="value">@Model.Mensaje</span>
        </div>

        <div class="notif-detail-row">
            <span class="label">Relacionado con</span>
            <span class="value">
                <span class="badge bg-primary">Tiquete</span> #@Model.IdTiquete
            </span>
        </div>
    </div>

</div>
