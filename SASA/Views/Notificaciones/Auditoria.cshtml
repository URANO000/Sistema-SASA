@model SASA.ViewModels.Notificaciones.NotificacionAuditoriaViewModel
@{
    ViewData["Title"] = "Auditoría de Notificaciones";
}

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
            <div class="text-muted small">
                Auditoría de notificaciones enviadas.
            </div>
        </div>

        <form method="get" class="audit-filters row g-2 mb-3">
            <div class="col-md-3">
                <input name="q" value="@Model.Q" class="form-control" placeholder="Buscar por usuario, tiquete, tipo, mensaje">
            </div>

            <div class="col-md-2">
                <select name="tipo" class="form-select">
                    <option value="">Tipo</option>
                    <option value="NuevoComentario" selected="@(Model.Tipo == "NuevoComentario")">NuevoComentario</option>
                </select>
            </div>

            <div class="col-md-2">
                <select name="estado" class="form-select">
                    <option value="">Estado</option>
                    <option value="NoLeida" selected="@(Model.Estado == "NoLeida")">NoLeida</option>
                    <option value="Leida" selected="@(Model.Estado == "Leida")">Leida</option>
                </select>
            </div>

            <div class="col-md-2">
                <input name="fecha" value="@(Model.Fecha?.ToString("yyyy-MM-dd"))" class="form-control" type="date">
            </div>

            <div class="col-md-3">
                <button class="btn btn-outline-secondary w-100">
                    <i class="bi bi-funnel"></i> Filtrar
                </button>
            </div>
        </form>

        <table class="table sasa-table">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Tipo</th>
                    <th>Relacionado</th>
                    <th>Destinatario</th>
                    <th>Estado</th>
                    <th>Detalle</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Elementos.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-muted">No hay notificaciones con esos filtros.</td>
                    </tr>
                }
                else
                {
                    foreach (var n in Model.Elementos)
                    {
                        <tr>
                            <td>@n.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="badge bg-primary">@n.TipoEvento</span></td>
                            <td>Tiquete #@n.IdTiquete</td>
                            <td>@n.Destinatario</td>
                            <td>
                                @if (n.Estado == "Leida")
                                {
                                    <span class="badge bg-success">Leída</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">No leída</span>
                                }
                            </td>
                            <td class="sasa-actions">
                                <a asp-controller="Notificaciones" asp-action="AuditoriaDetalle" asp-route-id="@n.IdNotificacion">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        @{
            var totalPaginas = (int)Math.Ceiling(Model.TotalRegistros / (double)Model.TamanoPagina);
        }

        @if (totalPaginas > 1)
        {
            <nav>
                <ul class="pagination">
                    @for (int p = 1; p <= totalPaginas; p++)
                    {
                        <li class="page-item @(p == Model.Pagina ? "active" : "")">
                            <a class="page-link"
                               asp-action="Auditoria"
                               asp-route-q="@Model.Q"
                               asp-route-tipo="@Model.Tipo"
                               asp-route-estado="@Model.Estado"
                               asp-route-fecha="@(Model.Fecha?.ToString("yyyy-MM-dd"))"
                               asp-route-pagina="@p"
                               asp-route-tamanoPagina="@Model.TamanoPagina">
                                @p
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>
