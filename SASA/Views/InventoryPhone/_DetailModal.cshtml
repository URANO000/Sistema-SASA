@model DataAccess.Modelos.DTOs.InventarioTelefono.ActivoTelefonoDetailDto

<div class="modal-header">
    <h5 class="modal-title">
        Detalle del Teléfono — <span class="fw-semibold">@Model.NombreColaborador</span>
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
</div>

<div class="modal-body form-content">
    <div class="row g-3">
        <div class="col-md-6">
            <div class="border rounded p-3">
                <div class="text-muted small">Colaborador</div>
                <div class="fw-semibold">@Model.NombreColaborador</div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="border rounded p-3">
                <div class="text-muted small">Departamento</div>
                <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.Departamento) ? Model.Departamento : "-")</div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="border rounded p-3">
                <div class="text-muted small">Operador</div>
                <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.Operador) ? Model.Operador : "-")</div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="border rounded p-3">
                <div class="text-muted small">Número celular</div>
                <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.NumeroCelular) ? Model.NumeroCelular : "-")</div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="border rounded p-3">
                <div class="text-muted small">Correo</div>
                <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.CorreoSistemasAnaliticos) ? Model.CorreoSistemasAnaliticos : "-")</div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="border rounded p-3">
                <div class="text-muted small">Modelo</div>
                <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.Modelo) ? Model.Modelo : "-")</div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="border rounded p-3">
                <div class="text-muted small">IMEI</div>
                <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.IMEI) ? Model.IMEI : "-")</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="border rounded p-3">
                <div class="text-muted small">Cargador</div>
                <div class="fw-semibold">@(Model.Cargador ? "Sí" : "No")</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="border rounded p-3">
                <div class="text-muted small">Auriculares</div>
                <div class="fw-semibold">@(Model.Auriculares ? "Sí" : "No")</div>
            </div>
        </div>
    </div>
</div>

<div class="modal-footer modal-footer-custom">
    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Cerrar</button>
</div>