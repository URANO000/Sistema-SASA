@model SASA.ViewModels.InventarioTelefono.CrearTelefonoViewModel

<div class="modal-header">
    <h5 class="modal-title">Editar Teléfono</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
</div>

<form id="editPhoneForm" method="post" class="form-container">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="IdActivoTelefono" />

    <div class="modal-body form-content scroll-hidden">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                Revisá los campos marcados.
            </div>
        }

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Nombre del colaborador</label>
                <input asp-for="NombreColaborador" class="form-control" />
                <span asp-validation-for="NombreColaborador" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">Departamento</label>
                <input asp-for="Departamento" class="form-control" />
                <span asp-validation-for="Departamento" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">Operador</label>
                <input asp-for="Operador" class="form-control" />
                <span asp-validation-for="Operador" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">Número celular</label>
                <input asp-for="NumeroCelular" class="form-control" />
                <span asp-validation-for="NumeroCelular" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">Correo Sistemas Analíticos</label>
                <input asp-for="CorreoSistemasAnaliticos" class="form-control" />
                <span asp-validation-for="CorreoSistemasAnaliticos" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">Modelo</label>
                <input asp-for="Modelo" class="form-control" />
                <span asp-validation-for="Modelo" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">IMEI</label>
                <input asp-for="IMEI" class="form-control" />
                <span asp-validation-for="IMEI" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <div class="form-check mt-4">
                    <input asp-for="Cargador" class="form-check-input" />
                    <label asp-for="Cargador" class="form-check-label">Cargador</label>
                </div>
                <span asp-validation-for="Cargador" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <div class="form-check mt-4">
                    <input asp-for="Auriculares" class="form-check-input" />
                    <label asp-for="Auriculares" class="form-check-label">Auriculares</label>
                </div>
                <span asp-validation-for="Auriculares" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="modal-footer modal-footer-custom modal-footer-sticky">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary">Guardar cambios</button>
    </div>
</form>