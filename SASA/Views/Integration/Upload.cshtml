@{
    ViewData["Title"] = "Carga de Información";
}

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-body">

            <h4 class="mb-1">Carga de Información</h4>
            <p class="text-muted mb-4">
                Subir archivos para procesos de integración.
            </p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            }

            <form asp-action="Upload" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Archivo (.xlsx)</label>
                    <input type="file" name="archivo" class="form-control" accept=".xlsx" required />
                </div>

                <!-- Si luego querés elegir módulo/tipo, lo conectamos a un parámetro.
                     Por ahora, tu controlador asume Inventario/Importacion -->
                <div class="mb-3">
                    <label class="form-label">Tipo de integración</label>
                    <select class="form-select" disabled>
                        <option selected>Inventario (Activos)</option>
                    </select>
                </div> 

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Volver al módulo
                    </a>

                    <div>
                        <a asp-action="Index" class="btn btn-outline-secondary me-2">
                            Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary">
                            Subir archivo
                        </button>
                    </div>
                </div>
            </form>

        </div>
    </div>
</div>