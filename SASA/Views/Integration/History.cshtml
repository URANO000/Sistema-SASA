@model List<DataAccess.Modelos.Entidades.Integracion.IntegracionHistorial>

@{
    ViewData["Title"] = "Historial de Integraciones";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-1"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
                <div class="me-3">
                    <h4 class="mb-1 text-break">Historial de Integraciones</h4>
                    <p class="text-muted mb-0">
                        Registro de importaciones/exportaciones realizadas en el sistema.
                    </p>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver al módulo</a>
                    <a asp-action="Upload" class="btn btn-primary">Nueva carga</a>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha</th>
                            <th>Proceso</th>
                            <th>Módulo</th>
                            <th>Archivo</th>
                            <th>Estado</th>
                            <th class="text-end">Filas</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    No hay integraciones registradas aún.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var h in Model)
                            {
                                <tr>
                                    <td>@h.Fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@h.TipoProceso</td>
                                    <td>@h.Modulo</td>
                                    <td>@h.NombreArchivo</td>
                                    <td>
                                        @{
                                            var badge = h.Estado switch
                                            {
                                                "Importado" => "bg-success",
                                                "Validado" => "bg-primary",
                                                "Cargado" => "bg-secondary",
                                                "Fallido" => "bg-danger",
                                                "Deshabilitado" => "bg-dark",
                                                _ => "bg-warning"
                                            };
                                        }
                                        <span class="badge @badge">@h.Estado</span>
                                    </td>
                                    <td class="text-end">
                                        @h.FilasValidas/@h.TotalFilas
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex flex-column align-items-end gap-2">
                                            @if (h.Estado != "Deshabilitado")
                                            {
                                                <a asp-action="Validation"
                                                       asp-route-historialId="@h.Id"
                                                       class="btn btn-sm btn-outline-primary"
                                                       style="min-width: 130px;">
                                                    Ver validación
                                                </a>
                                            }

                                            @if (h.Estado == "Fallido")
                                            {
                                                <form asp-action="ReprocesarArchivo" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="historialId" value="@h.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-warning" style="min-width: 130px;">
                                                        Reprocesar
                                                    </button>
                                                </form>

                                                <form asp-action="DeshabilitarArchivo" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="historialId" value="@h.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-dark" style="min-width: 130px;">
                                                        Deshabilitar
                                                    </button>
                                                </form>
                                            }
                                            @if (h.Estado == "Deshabilitado")
                                            {
                                                <span class="text-muted small">Archivo deshabilitado</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>