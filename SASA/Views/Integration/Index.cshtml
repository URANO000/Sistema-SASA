@{
    ViewData["Title"] = "Integración";
}

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-body">

            <div class="text-center mb-4">
                <h4 class="fw-bold">Módulo de Integración</h4>
                <p class="text-muted mb-0">
                    Gestión de procesos de integración entre sistemas, activos y datos.
                </p>
            </div>

            <div class="row g-4 justify-content-center">

                <div class="col-12 col-md-6 col-lg-4">
                    <a asp-action="Upload"
                       class="card h-100 text-decoration-none shadow-sm border-0 integracion-card">
                        <div class="card-body text-center p-4">
                            <h5 class="fw-semibold mb-2">Carga de Información</h5>
                            <p class="text-muted small mb-0">
                                Subir archivos o datos externos al sistema.
                            </p>
                        </div>
                    </a>
                </div>

                <div class="col-12 col-md-6 col-lg-4">
                    <a asp-action="History"
                       class="card h-100 text-decoration-none shadow-sm border-0 integracion-card">
                        <div class="card-body text-center p-4">
                            <h5 class="fw-semibold mb-2">Historial de Integraciones</h5>
                            <p class="text-muted small mb-0">
                                Registro de integraciones realizadas.
                            </p>
                        </div>
                    </a>
                </div>

            </div>

        </div>
    </div>
</div>