@model SASA.ViewModels.Integracion.ValidacionImportacionTelefonoViewModel

@{
    ViewData["Title"] = "Detección automática de teléfonos";
    var tieneErrores = Model.Errores != null && Model.Errores.Any();
    var tieneFilas = Model.FilasDetectadas != null && Model.FilasDetectadas.Any();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-1"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
                <div>
                    <h4 class="mb-1">Detección automática de teléfonos</h4>
                    <div class="text-muted">Archivo: <strong>@Model.NombreArchivo</strong></div>
                    <div class="text-muted small">
                        Revise los teléfonos detectados, edite los campos necesarios y seleccione cuáles desea registrar en el inventario.
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <a asp-action="Upload" class="btn btn-outline-primary">Nueva carga</a>
                    <a asp-action="History" class="btn btn-outline-secondary">Ver historial</a>
                </div>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            }

            <div class="row g-3 mb-3">
                <div class="col-12 col-md-4">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted">Total filas</div>
                        <div class="fs-4 fw-bold">@Model.TotalFilas</div>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted">Filas válidas actuales</div>
                        <div class="fs-4 fw-bold">@Model.FilasValidas</div>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted">Filas con error</div>
                        <div class="fs-4 fw-bold">@Model.FilasConError</div>
                    </div>
                </div>
            </div>

            @if (tieneErrores)
            {
                <div class="alert alert-warning">
                    <div class="fw-semibold mb-2">Errores detectados</div>
                    <ul class="mb-0">
                        @foreach (var e in Model.Errores)
                        {
                            <li>@(e.NumeroFila > 0 ? $"Fila {e.NumeroFila}: " : string.Empty)@e.Mensaje</li>
                        }
                    </ul>
                </div>
            }

            @if (!tieneFilas)
            {
                <div class="text-muted">No hay teléfonos detectados para mostrar.</div>
            }
            else
            {
                <form asp-action="ConfirmImportPhones" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="HistorialId" />
                    <input type="hidden" asp-for="NombreArchivo" />

                    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                        <div class="text-muted small">
                            Solo se registrarán las filas seleccionadas.
                        </div>
                        <button type="submit" class="btn btn-success">
                            Registrar teléfonos seleccionados
                        </button>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered table-sm align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Registrar</th>
                                    <th>Fila</th>
                                    <th>Nombre colaborador</th>
                                    <th>Departamento</th>
                                    <th>Operador</th>
                                    <th>Número celular</th>
                                    <th>Correo Sistemas Analíticos</th>
                                    <th>Modelo</th>
                                    <th>IMEI</th>
                                    <th>Cargador</th>
                                    <th>Auriculares</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.FilasDetectadas.Count; i++)
                                {
                                    <tr>
                                        <td class="text-center">
                                            <input type="hidden" asp-for="FilasDetectadas[i].NumeroFila" />
                                            <input asp-for="FilasDetectadas[i].Seleccionado" class="form-check-input" />
                                        </td>

                                        <td>@Model.FilasDetectadas[i].NumeroFila</td>

                                        <td>
                                            <input asp-for="FilasDetectadas[i].NombreColaborador" class="form-control form-control-sm" />
                                        </td>

                                        <td>
                                            <input asp-for="FilasDetectadas[i].Departamento" class="form-control form-control-sm" />
                                        </td>

                                        <td>
                                            <input asp-for="FilasDetectadas[i].Operador" class="form-control form-control-sm" />
                                        </td>

                                        <td>
                                            <input asp-for="FilasDetectadas[i].NumeroCelular" class="form-control form-control-sm" />
                                        </td>

                                        <td>
                                            <input asp-for="FilasDetectadas[i].CorreoSistemasAnaliticos" class="form-control form-control-sm" />
                                        </td>

                                        <td>
                                            <input asp-for="FilasDetectadas[i].Modelo" class="form-control form-control-sm" />
                                        </td>

                                        <td>
                                            <input asp-for="FilasDetectadas[i].IMEI" class="form-control form-control-sm" />
                                        </td>

                                        <td class="text-center">
                                            <input asp-for="FilasDetectadas[i].Cargador" class="form-check-input" />
                                        </td>

                                        <td class="text-center">
                                            <input asp-for="FilasDetectadas[i].Auriculares" class="form-check-input" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </form>
            }

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}