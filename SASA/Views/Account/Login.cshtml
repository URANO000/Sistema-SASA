@model SASA.ViewModels.Auth.LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="container-fluid">
    <div class="row min-vh-100">
        <div class="col-12 d-flex align-items-center justify-content-center py-4 py-md-5">
            <div class="w-100 px-3 px-sm-4" style="max-width: 420px;">
                <div class="card auth-card shadow-sm">
                    <div class="card-body p-4">
                        <h1 class="h4 auth-title text-center">Iniciar Sesión</h1>
                        <p class="auth-subtitle text-center">Ingresa a tu cuenta para continuar</p>

                        <form method="post" action="/login" novalidate>
                            @Html.AntiForgeryToken()

                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label">Correo Electrónico</label>
                                <input asp-for="Email" class="form-control auth-input" placeholder="tu@email.com" autocomplete="username" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label">Contraseña</label>
                                <input asp-for="Password" type="password" class="form-control auth-input" placeholder="Tu contraseña" autocomplete="current-password" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <button type="submit" class="btn btn-custom w-100">Iniciar Sesión</button>
                        </form>

                        <div class="mt-3 text-center">
                            <a class="auth-link" href="/forgot-password">¿Olvidaste tu contraseña?</a>
                        </div>
                    </div>
                </div>

                <div class="text-center text-muted small mt-3">
                    Sistema de gestión SASA
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}