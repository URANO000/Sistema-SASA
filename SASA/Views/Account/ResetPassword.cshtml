@model SASA.ViewModels.Auth.ResetPasswordViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Restablecer contraseña";
}

<div class="card shadow-sm">
    <div class="card-body p-4">
        <h1 class="h4 mb-2">Restablecer contraseña</h1>

        <div class="alert alert-light border small mb-4" role="alert">
            <div class="fw-semibold mb-1">Recomendaciones de seguridad</div>
            <ul class="mb-0 ps-3">
                <li>Al menos <strong>8 caracteres</strong>.</li>
                <li>Incluye <strong>mayúsculas</strong>, <strong>minúsculas</strong>, <strong>números</strong> y <strong>símbolos</strong>.</li>
                <li>Evita contraseñas comunes o información personal.</li>
            </ul>
        </div>

        <form method="post" action="/reset-password/@Model.Token">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <div class="mt-2 mb-4 text-center">
                <a href="/forgot-password" class="text-danger fw-semibold">
                    ¿El enlace expiró? Solicita uno nuevo
                </a>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label">Nueva contraseña</label>
                <input asp-for="NewPassword" type="password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Confirmar contraseña</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-custom w-100">Guardar</button>

        </form>

        <div class="mt-3">
            <a href="/login">Volver</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
