@model SASA.ViewModels.Auth.SetPasswordViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Crear contraseña";
}

<div class="card shadow-sm">
    <div class="card-body p-4">
        <h1 class="h4 mb-2">Crear contraseña</h1>

        <!-- Mensaje verde de cuenta verificada -->
        <div class="alert alert-success small mb-4" role="alert">
            <div class="fw-semibold mb-1">Cuenta verificada</div>
            Ya puedes crear tu contraseña para iniciar sesión.
        </div>

        <div class="alert alert-light border small mb-4" role="alert">
            <div class="fw-semibold mb-1">Recomendaciones de seguridad</div>
            <ul class="mb-0 ps-3">
                <li>Al menos <strong>8 caracteres</strong>.</li>
                <li>Incluye <strong>mayúsculas</strong>, <strong>minúsculas</strong>, <strong>números</strong> y <strong>símbolos</strong>.</li>
                <li>Evita contraseñas comunes o información personal.</li>
            </ul>
        </div>

        <form method="post" action="/set-password/@Model.Token">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label">Nueva contraseña</label>
                <input asp-for="NewPassword" class="form-control" type="password" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Confirmar contraseña</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-custom w-100">Guardar contraseña</button>

            <!-- Acción secundaria -->
            <a class="btn btn-outline-secondary w-100 mt-2" asp-controller="Account" asp-action="Login">
                Volver al inicio de sesión
            </a>
        </form>

        <div class="mt-4 text-center small">
            <span class="text-muted">¿El enlace venció?</span>
            <a asp-controller="Account" asp-action="ForgotPassword" class="fw-semibold">Solicitar uno nuevo</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}