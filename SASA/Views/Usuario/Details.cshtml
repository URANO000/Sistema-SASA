@using SASA.ViewModels.Usuario
@model UsuarioDetalleViewModel
@{
    ViewData["Title"] = "Detalles del Usuario";
}

<!-- HEADER -->
<a onclick="history.back()" class="btn btn-link px-0">
    <i class="bi bi-arrow-left"></i> Volver
</a>
<div class="card mb-3">
    <div class="card-body">
        <div class="ticket-header mb-4">

            <div class="d-flex justify-content-between align-items-center mt-2">
                <h4 class="mb-0 fw-bold">Detalles del Usuario</h4>

                @if(Model.Estado == "Activo")
                {
                    <span class="badge bg-success">
                        Usuario Activo
                    </span>
                }
                else
                {
                    <span class="badge bg-secondary">
                        Usuario Inactivo
                    </span>
                }
            </div>
        </div>
    </div>
</div>

<div class="row">

    <!-- MAIN -->
    <div class="col-lg">

        <!-- IDENTIDAD -->
        <div class="card mb-4">
            <div class="card-body">
                <h6 class="section-title">Identidad del Usuario</h6>

                <dl class="row mb-0">
                    <dt class="col-4">Nombre Completo</dt>
                    <dd class="col-8">@Model.NombreCompleto</dd>
@* 
                    <dt class="col-4">No. Empleado</dt>
                    <dd class="col-8">EMP-1023</dd> *@

                    <dt class="col-4">Correo</dt>
                    <dd class="col-8">@Model.CorreoEmpresa</dd>
                </dl>
            </div>
        </div>

        <!-- CONTEXTO ORGANIZACIONAL -->
        <div class="card mb-4">
            <div class="card-body">
                <h6 class="section-title">Información Organizacional</h6>

                <dl class="row mb-0">
                    <dt class="col-4">Departamento</dt>
                    <dd class="col-8">@Model.Departamento</dd>

                    <dt class="col-4">Puesto</dt>
                    <dd class="col-8">@Model.Puesto</dd>

                    <dt class="col-4">Rol</dt>
                    <dd class="col-8">@Model.Rol</dd>
                </dl>
            </div>
        </div>

        <hr />

        <div class="card mb-4">
            <div class="card-body">
                <div class="text-uppercase text-muted mb-3" style="font-size: .75rem; letter-spacing: .04em;">
                    Intentos de inicio de sesión (últimos 15)
                </div>

                @if (Model.IntentosLogin == null || !Model.IntentosLogin.Any())
                {
                    <div class="alert alert-info mb-0">
                        No hay intentos registrados para este usuario.
                    </div>
                }
                else
                {
                    <div class="p-3" style="max-height: 260px; overflow-y: auto;">
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr class="text-muted" style="font-size:.875rem;">
                                        <th>Fecha (Local)</th>
                                        <th>Resultado</th>
                                        <th>Motivo</th>
                                        <th>IP</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var intento in Model.IntentosLogin)
                                    {
                                        <tr>
                                            <td>@intento.FechaLocal</td>
                                            <td>
                                                @if (intento.Exitoso)
                                                {
                                                    <span class="badge bg-success">Exitoso</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Fallido</span>
                                                }
                                            </td>
                                            <td>
                                                @{
                                                    string motivo = intento.MotivoFallo ?? "";
                                                    motivo = motivo switch
                                                    {
                                                        "InvalidCredentials" => "Credenciales inválidas",
                                                        "UserNotFound" => "Usuario no existe",
                                                        "LockedOut" => "Bloqueo temporal",
                                                        "NotAllowed" => "No permitido (sin activar)",
                                                        "Disabled" => "Cuenta desactivada",
                                                        _ => (string.IsNullOrWhiteSpace(motivo) ? "-" : motivo)
                                                    };
                                                }
                                                @(intento.Exitoso ? "-" : motivo)
                                            </td>
                                            <td>
                                                @{
                                                    var ipMostrar =
                                                    (intento.IpAddress == "::1" || intento.IpAddress == "127.0.0.1")
                                                    ? "Localhost"
                                                    : intento.IpAddress;
                                                }
                                                <span class="badge bg-light text-dark">@ipMostrar</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div> 
</div>
