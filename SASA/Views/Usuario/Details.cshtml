@using SASA.ViewModels.Usuario
@model UsuarioDetalleViewModel
@{
    ViewData["Title"] = "Detalles del Usuario";
}

<!-- HEADER -->
<div class="card mb-3">
    <div class="card-body">
        <div class="ticket-header mb-4">
            <a asp-controller="Usuario" asp-action="Index" class="btn btn-link px-0">
                <i class="bi bi-arrow-left"></i> Volver al listado
            </a>

            <div class="d-flex justify-content-between align-items-center mt-2">
                <h4 class="mb-0 fw-bold">Detalles del Usuario</h4>

                @if(Model.Estado == "Activo")
                {
                    <span class="badge bg-success">
                        Usuario Activo
                    </span>
                }
                else
                {
                    <span class="badge bg-secondary">
                        Usuario Inactivo
                    </span>
                }
            </div>
        </div>
    </div>
</div>

<div class="row">

    <!-- MAIN -->
    <div class="col-lg">

        <!-- IDENTIDAD -->
        <div class="card mb-4">
            <div class="card-body">
                <h6 class="section-title">Identidad del Usuario</h6>

                <dl class="row mb-0">
                    <dt class="col-4">Nombre Completo</dt>
                    <dd class="col-8">@Model.NombreCompleto</dd>
@* 
                    <dt class="col-4">No. Empleado</dt>
                    <dd class="col-8">EMP-1023</dd> *@

                    <dt class="col-4">Correo</dt>
                    <dd class="col-8">@Model.CorreoEmpresa</dd>
                </dl>
            </div>
        </div>

        <!-- CONTEXTO ORGANIZACIONAL -->
        <div class="card mb-4">
            <div class="card-body">
                <h6 class="section-title">Información Organizacional</h6>

                <dl class="row mb-0">
                    <dt class="col-4">Departamento</dt>
                    <dd class="col-8">@Model.Departamento</dd>

                    <dt class="col-4">Puesto</dt>
                    <dd class="col-8">@Model.Puesto</dd>

                    <dt class="col-4">Rol</dt>
                    <dd class="col-8">@Model.Rol</dd>
                </dl>
            </div>
        </div>

        <hr />

        <h5 class="mt-4">Intentos de inicio de sesión (últimos 15)</h5>

        @if (Model.IntentosLogin == null || !Model.IntentosLogin.Any())
        {
            <div class="alert alert-info">
                No hay intentos registrados para este usuario.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Fecha (Local)</th>
                            <th>Resultado</th>
                            <th>Motivo</th>
                            <th>IP</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var intento in Model.IntentosLogin)
                        {
                            <tr>
                                <td>@intento.FechaLocal</td>
                                <td>
                                    @if (intento.Exitoso)
                                    {
                                        <span class="badge bg-success">Exitoso</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Fallido</span>
                                    }
                                </td>
                                <td>@(intento.Exitoso ? "-" : intento.MotivoFallo)</td>
                                <td>@(intento.IpAddress == "::1" ? "Localhost" : intento.IpAddress)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
@* 
        <!-- ACTIVIDAD EN TIQUETES -->
        <div class="card">
            <div class="card-body">
                <h6 class="section-title">Actividad en el Sistema de Tiquetes</h6>

               <h6 class="section-title">Resumen Operativo</h6>

                <dl class="row mb-0">
                    <dt class="col-7">Tiquetes Abiertos</dt>
                    <dd class="col-5">3</dd>

                    <dt class="col-7">Tiquetes Cerrados</dt>
                    <dd class="col-5">12</dd>

                    <dt class="col-7">Última Actividad</dt>
                    <dd class="col-5">12/03/2025</dd>
                </dl>
            </div>
        </div>

    </div>

    <!-- SIDE -->
    <div class="col-lg-4">

        <!-- MÉTRICAS -->
        <div class="card mb-4">
            <div class="card-body">
                <h6 class="section-title">Resumen Operativo</h6>

                <dl class="row mb-0">
                    <dt class="col-7">Tiquetes Abiertos</dt>
                    <dd class="col-5">3</dd>

                    <dt class="col-7">Tiquetes Cerrados</dt>
                    <dd class="col-5">12</dd>

                    <dt class="col-7">Última Actividad</dt>
                    <dd class="col-5">12/03/2025</dd>
                </dl>
            </div>
        </div>

         <!-- ACCIONES -->
        <div class="card">
            <div class="card-body">
                <h6 class="section-title">Acciones</h6>

                <div class="d-grid gap-2">
                    <a class="btn btn-primary-custom text-white">
                        Ver Tiquetes del Usuario
                    </a>

                    <a class="btn btn-outline-secondary">
                        Editar Información Básica
                    </a>
                </div>
            </div>
        </div> *@

    </div> 
</div>
