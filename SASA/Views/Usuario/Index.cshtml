@using SASA.ViewModels.Usuario
@model IReadOnlyList<UsuarioListaViewModel>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}
<div class="container-fluid">
    <!-- Header -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="mb-0 fw-bold">Gestión de Usuarios</h2>
                <button class="btn btn-custom"
                        data-bs-toggle="modal" data-bs-target="#addUserModal">
                    <i class="bi bi-plus-lg"></i>
                    Nuevo Usuario
                </button>
            </div>
            <!-- Filters -->
            <div class="row g-2 align-items-end mb-3">
                <div class="col-md-4">
                    <label class="form-label">Buscar</label>
                    <input type="text" class="form-control" placeholder="Nombre o No. Empleado">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Departamento</label>
                    <select class="form-select">
                        <option value="">Todos</option>
                        <option>TI</option>
                        <option>RRHH</option>
                        <option>Finanzas</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Estado</label>
                    <select class="form-select">
                        <option value="">Todos</option>
                        <option>Activo</option>
                        <option>Inactivo</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100">
                        <i class="bi bi-funnel"></i>
                        Filtrar
                    </button>
                </div>
            </div>
            <!--Table comes here-->
            <div class="table-responsive card">
                <table class="table table-hover align-middle sasa-table">
                    <thead>
                        <tr>
                            <th>Acciones</th>
                            <th>Nombre Completo</th>
                            <th>Correo</th>
                            <th>Departamento</th>
                            <th>Puesto</th>
                            <th>Estado</th>
                            <th>Rol</th>
                        </tr>
                    </thead>
                    <tbody>
                            @foreach(var u in Model)
                            {
                            <tr>
                                <td>
                                    <a class="btn btn-link icon-btn" asp-area="" asp-controller="Usuario" asp-action="Details">
                                        <i class="bi bi-eye detail-btn"></i>
                                    </a>
                                    <a class="btn btn-link icon-btn" asp-area="" asp-controller="Usuario" asp-action="Edit">
                                        <i class="fa-regular fa-pen-to-square edit-btn"></i>
                                    </a>
                                </td>

                                <td> @u.NombreCompleto</td>
                                <td>@u.CorreoEmpresa</td>
                                <td>@u.Departamento</td>
                                <td>@u.Puesto</td>
                                @if(u.Estado == "Activo")
                                {
                                    <td><span class="badge bg-success">Activo</span></td>
                                }
                                else
                                {
                                    <td><span class="badge bg-secondary">Inactivo</span></td>
                                }
                                <td>@u.Rol</td>
                            </tr>
                            }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@await Html.PartialAsync("_AddModal")