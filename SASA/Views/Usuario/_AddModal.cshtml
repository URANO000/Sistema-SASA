@using SASA.ViewModels.Usuario
@model CrearUsuarioViewModel;
<div class="modal fade" id="addUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <form asp-action="Add"
                  asp-controller="Usuario"
                  method="post"
                  id="createUserForm">

                @Html.AntiForgeryToken()

                <!-- Header -->
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-person-plus me-2"></i>
                        Crear Nuevo Usuario
                    </h5>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"></button>
                </div>

                <!-- Body -->
                <div class="modal-body">
                    <p class="section-subtitle">
                        Ingrese la información básica para registrar un nuevo usuario en el sistema.
                    </p>

                    <div class="row g-3">

                        <!-- Primer Nombre -->
                        <div class="col-md-6">
                            <label asp-for="PrimerNombre" class="form-label required-field">Primer Nombre</label>
                            <input asp-for="PrimerNombre" class="form-control" />
                            <span asp-validation-for="PrimerNombre" class="text-danger"></span>
                        </div>

                        <!-- Segundo Nombre -->
                        <div class="col-md-6">
                            <label asp-for="SegundoNombre" class="form-label">Segundo Nombre</label>
                            <input asp-for="SegundoNombre" class="form-control" />
                        </div>

                        <!-- Primer Apellido -->
                        <div class="col-md-6">
                            <label asp-for="PrimerApellido" class="form-label required-field">Primer Apellido</label>
                            <input asp-for="PrimerApellido" class="form-control" />
                            <span asp-validation-for="PrimerApellido" class="text-danger"></span>
                        </div>

                        <!-- Segundo Apellido -->
                        <div class="col-md-6">
                            <label asp-for="SegundoApellido" class="form-label">Segundo Apellido</label>
                            <input asp-for="SegundoApellido" class="form-control" />
                        </div>

                        <!-- Correo -->
                        <div class="col-md-6">
                            <label asp-for="CorreoEmpresa" class="form-label required-field">Correo Empresarial</label>
                            <input asp-for="CorreoEmpresa" class="form-control" />
                            <span asp-validation-for="CorreoEmpresa" class="text-danger"></span>
                        </div>

                        <!-- Departamento -->
                        <div class="col-md-6">
                            <label asp-for="Departamento" class="form-label required-field"></label>
                            <select asp-for="Departamento" class="form-select">
                                <option value="">Seleccione un departamento</option>
                                <option>TI</option>
                                <option>RRHH</option>
                                <option>Ventas</option>
                            </select>
                            <span asp-validation-for="Departamento" class="text-danger"></span>
                        </div>

                        <!-- Puesto -->
                        <div class="col-md-6">
                            <label asp-for="Puesto" class="form-label required-field"></label>
                            <select asp-for="Puesto" class="form-select">
                                <option value="">Seleccione un puesto</option>
                                <option>Analista de Soporte</option>
                                <option>Administrador</option>
                                <option>Asesor de ventas</option>
                            </select>
                            <span asp-validation-for="Puesto" class="text-danger"></span>
                        </div>

                        <!-- Rol (single selection) -->
                        <div class="col-md-6">
                            <label asp-for="Rol" class="form-label required-field">Rol</label>
                            <select asp-for="Rol"
                                    asp-items="Model.RolesDisponibles"
                                    class="form-select">
                                <option value="">Seleccione un rol</option>
                            </select>

                            <span asp-validation-for="Rol" class="text-danger"></span>

                            <small class="text-muted">
                                El rol define los permisos iniciales del usuario.
                            </small>
                        </div>

                    </div>
                </div>

                <!-- Footer -->
                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="submit"
                            class="btn btn-success text-white">
                        Crear Usuario
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>
