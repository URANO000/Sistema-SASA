@model IEnumerable<UserListItemVm>

@{
    ViewData["Title"] = "Gestión de usuarios";
}

<h2>Gestión de usuarios</h2>

<p>
    <a asp-area="Admin" asp-controller="Users" asp-action="Create" class="btn btn-primary">
        Crear usuario
    </a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Email</th>
            <th>Estado</th>
            <th>Email confirmado</th>
            <th>Intentos fallidos</th>
            <th>Lockout end</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.Email</td>
                <td>
                    @if (u.Estado)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {

                        <span class="badge bg-danger">Inactivo</span>
                    }
                </td>
                <td>@(u.EmailConfirmed ? "Sí" : "No")</td>
                <td>@u.AccessFailedCount</td>
                <td>@(u.LockoutEnd?.ToString() ?? "-")</td>
                <td class="text-end">
                    <a asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@u.Id"
                       class="btn btn-sm btn-outline-secondary">Editar</a>

                    <form asp-area="Admin" asp-controller="Users" asp-action="ToggleEstado" asp-route-id="@u.Id"
                          method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm @(u.Estado ? "btn-outline-danger" : "btn-outline-success")" type="submit">
                            @(u.Estado ? "Desactivar" : "Activar")
                        </button>
                    </form>

                    <form asp-area="Admin" asp-controller="Users" asp-action="ResetPassword" asp-route-id="@u.Id"
                          method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-warning" type="submit">
                            Restablecer contraseña
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
